{
  "name": "@udtp/shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript types, constants, and utilities used by the frontend (and referenced as the source of truth for backend schema parity).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
