# Development image — runs the Vite dev server with hot reload.
FROM node:20-alpine

WORKDIR /app

# Install deps first for better layer caching. Shared package is bind-mounted
# at /shared by docker-compose and linked via npm workspaces at the repo root,
# but for a standalone frontend-only image build we copy just the frontend.
COPY package*.json ./
RUN npm install

COPY . .

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
