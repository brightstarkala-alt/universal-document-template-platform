# =============================================================================
# ROOT ENVIRONMENT FILE (used by docker-compose to fan values out to services)
# Copy this file to `.env` and fill in real values.
# Service-specific example files: frontend/.env.example, backend/.env.example
# =============================================================================

# ---- General ----
ENVIRONMENT=development          # development | staging | production
PROJECT_NAME=universal-doc-template-platform

# ---- Ports ----
FRONTEND_PORT=5173
BACKEND_PORT=8000
LOCAL_POSTGRES_PORT=5432

# ---- Supabase (cloud project — used in all non-local envs) ----
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Local Postgres (optional, only for isolated local development) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_dev

# ---- OpenAI ----
OPENAI_API_KEY=

# ---- Backend ----
BACKEND_CORS_ORIGINS=["http://localhost:5173"]
LOG_LEVEL=INFO
